{
  "name": "hot2",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3011",
    "build": "next build",
    "start": "next start -p 3011",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude tests/db-baseline.test.ts --exclude tests/migrations.test.ts",
    "test:critical": "vitest run tests/article-pipeline-status.test.ts tests/event-clustering.test.ts tests/event-release-policy.test.ts tests/event-service.test.ts tests/event-push-delivery.test.ts tests/public-publication-service.test.ts tests/review-service.test.ts tests/source-service.test.ts tests/source-actions.test.ts tests/execution-concurrency.test.ts tests/timeout-cancellation.test.ts tests/maintenance-service.test.ts",
    "test:migrations": "vitest run tests/migrations.test.ts --maxWorkers=1 --reporter=verbose",
    "test:legacy-baseline": "vitest run tests/db-baseline.test.ts --maxWorkers=1 --reporter=verbose",
    "test:all": "npm run test && npm run test:migrations",
    "verify": "npm run lint && npm run typecheck && npm run test:all && npm run build",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "db:danger:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:baseline": "tsx scripts/db-baseline.ts",
    "db:migrate:status": "prisma migrate status",
    "db:danger:reset": "prisma migrate reset",
    "db:cleanup-logs": "tsx scripts/cleanup-logs.ts",
    "db:optimize": "tsx scripts/optimize-database.ts",
    "db:rebuild-public": "tsx scripts/rebuild-public-publication.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.11.1",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "iconv-lite": "^0.6.3",
    "lucide-react": "^0.525.0",
    "next": "^16.1.1",
    "next-themes": "^0.4.6",
    "node-cron": "^3.0.3",
    "prisma": "^6.11.1",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.3",
    "sonner": "^2.0.6",
    "tailwind-merge": "^3.3.1",
    "tsx": "^4.22.4",
    "xlsx": "^0.18.5",
    "z-ai-web-dev-sdk": "^0.0.18",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "25.9.2",
    "@types/node-cron": "^3.0.11",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^4.1.8",
    "eslint": "^9",
    "eslint-config-next": "^16.1.1",
    "happy-dom": "^20.10.3",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
